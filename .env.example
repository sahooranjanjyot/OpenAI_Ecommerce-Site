# ══════════════════════════════════════════════════════════════════════════════
# GroceryOS — Required Environment Variables
# Copy this file to .env.local and fill in all values marked REQUIRED
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/groceryos"    # REQUIRED

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"         # REQUIRED (for rate limiting, sessions)
REDIS_PASSWORD="your-redis-password"       # REQUIRED in production (min 32 chars)
REDIS_TLS="true"                           # Set to "true" in production

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-min-32-chars-random-string-here"    # REQUIRED — min 32 chars
CSRF_SECRET="change-me-csrf-secret-min-32-chars"          # REQUIRED

# ── Email (Resend) ────────────────────────────────────────────────────────────
# C-E-1 FIX: Key must be in env — never hardcoded in source
RESEND_API_KEY="re_your_actual_api_key"    # REQUIRED — rotate the old leaked key!
RESEND_SENDER_EMAIL="noreply@yourdomain.com"  # REQUIRED — must be verified in Resend

# Comma-separated list of allowed recipient domains (leave empty to allow all)
# H-E-3: Set this to restrict who the email endpoint can send to
ALLOWED_EMAIL_DOMAINS="yourdomain.com,customerexample.com"

# ── Audit ─────────────────────────────────────────────────────────────────────
AUDIT_HMAC_SECRET="change-me-audit-secret-min-32-chars"   # REQUIRED — min 32 chars

# ── Voice / Alexa ─────────────────────────────────────────────────────────────
# H-D-2: Alexa Skill ID validation — get from Alexa Developer Console
ALEXA_SKILL_ID="amzn1.ask.skill.your-skill-id-here"        # REQUIRED in production

# H-D-3: Google Actions Project ID for JWT audience validation
GOOGLE_ACTIONS_PROJECT_ID="your-google-actions-project-id" # REQUIRED in production

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."            # REQUIRED for Stripe payments
STRIPE_WEBHOOK_SECRET="whsec_..."         # REQUIRED for Stripe webhooks
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="https://yourdomain.com"
NEXT_PUBLIC_BASE_URL="https://yourdomain.com"
NODE_ENV="production"

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN="https://..."
LOG_LEVEL="info"
