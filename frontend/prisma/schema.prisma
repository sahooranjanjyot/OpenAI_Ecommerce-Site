/**
 * Prisma schema — GroceryOS
 *
 * FIX C-B4-1: Added @@index to ALL 37 models — zero indexes caused full table scans.
 * This is the single most impactful performance fix.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String?
  name          String
  phone         String?
  address       String
  sessionToken  String?
  loyaltyPoints Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  reviews       Review[]
  wishlists     Wishlist[]
  @@index([email])
  @@index([createdAt])
  @@index([sessionToken])
}

model Employee {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("staff")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  @@index([email])
  @@index([role, active])
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  price       Int       // stored in pence (integer) — FIX HIGH-B2-002 floating point
  category    String
  imageUrl    String?
  stock       Int       @default(0)
  sku         String?   @unique
  barcode     String?   @unique
  weight      Float?
  enabled     Boolean   @default(true)
  featured    Boolean   @default(false)
  vatRate     Int       @default(20) // percentage
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviews     Review[]
  wishlists   Wishlist[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  @@index([category])
  @@index([enabled, category])
  @@index([enabled, featured])
  @@index([sku])
  @@index([barcode])
  @@index([createdAt])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String  // e.g. "500g", "Red", "Large"
  sku       String? @unique
  price     Int     // pence override (0 = use parent price)
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
  @@index([sku])
}

model Order {
  id              Int         @id @default(autoincrement())
  customerId      Int?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  status          String      @default("new")
  statusNote      String?
  total           Int         // pence
  shippingAddr    String
  shippingCost    Int         @default(0)   // pence
  discountAmount  Int         @default(0)   // pence
  couponCode      String?
  affiliateCode   String?
  affiliateTracked Boolean    @default(false)
  notes           String?
  idempotencyKey  String?     @unique
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([affiliateCode])
  @@index([idempotencyKey])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Int     // pence at time of purchase
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  @@index([orderId])
  @@index([productId])
}

model Review {
  id         Int      @id @default(autoincrement())
  productId  Int
  customerId Int?
  rating     Int      // 1-5
  title      String?
  body       String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])
  @@index([productId])
  @@index([productId, approved])
  @@index([customerId])
  @@index([approved, createdAt])
}

model Wishlist {
  id         Int      @id @default(autoincrement())
  customerId Int
  productId  Int
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@unique([customerId, productId])
  @@index([customerId])
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String   // percentage | fixed | free_shipping
  value       Int      // percentage or pence
  minOrder    Int      @default(0)     // pence
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([code])
  @@index([active, expiresAt])
}

model GiftCard {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  balance   Int      // pence
  active    Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  @@index([code])
  @@index([active])
}

model LoyaltyAccount {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  points    Int      @default(0)
  tier      String   @default("bronze")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([email])
  @@index([tier])
}

model Subscription {
  id          Int      @id @default(autoincrement())
  customerId  Int
  productId   Int
  frequency   String   // weekly | fortnightly | monthly
  status      String   @default("active")
  nextOrderAt DateTime
  createdAt   DateTime @default(now())
  @@index([customerId])
  @@index([status, nextOrderAt])
}

model AbandonedCart {
  id          Int       @id @default(autoincrement())
  email       String
  cartData    String    // JSON
  recoveredAt DateTime?
  emailsSent  Int       @default(0)
  lastEmailAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([email])
  @@index([recoveredAt])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  confirmed   Boolean   @default(false)
  confirmToken String?
  unsubscribedAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([email])
  @@index([confirmed])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  resource  String
  userId    String
  ip        String
  payload   String?
  checksum  String
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource])
}

model Refund {
  id        Int      @id @default(autoincrement())
  orderId   Int
  amount    Int      // pence
  reason    String
  status    String   @default("pending")  // pending | processed | rejected
  processedBy String?
  createdAt DateTime @default(now())
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model Return {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productName String
  quantity    Int
  reason      String
  condition   String
  refundAmount Int     // pence
  restocked   Boolean @default(false)
  processedBy String?
  createdAt   DateTime @default(now())
  @@index([orderId])
  @@index([createdAt])
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  content     String
  excerpt     String?
  authorId    Int?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([slug])
  @@index([published, publishedAt])
}

model Location {
  id         Int            @id @default(autoincrement())
  name       String
  address    String
  city       String
  postcode   String
  active     Boolean        @default(true)
  stock      LocationStock[]
  @@index([city])
  @@index([postcode])
  @@index([active])
}

model LocationStock {
  id         Int      @id @default(autoincrement())
  locationId Int
  productId  Int
  quantity   Int      @default(0)
  location   Location @relation(fields: [locationId], references: [id])
  @@unique([locationId, productId])
  @@index([locationId])
  @@index([productId])
}

model PriceRule {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   // percentage | fixed | free_shipping
  target      String   // all | category:X | product:Y
  value       Int      // percentage or pence
  minQuantity Int      @default(1)
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([active, startDate, endDate])
  @@index([type])
}

model ModerationQueue {
  id         Int      @id @default(autoincrement())
  type       String   // review | qa | blog_comment
  entityId   Int
  content    String
  authorId   Int?
  status     String   @default("pending") // pending | approved | rejected
  reviewedBy Int?
  createdAt  DateTime @default(now())
  @@index([type, status])
  @@index([status, createdAt])
}

model DigitalDownload {
  id          Int       @id @default(autoincrement())
  orderId     Int
  productId   Int
  token       String    @unique
  downloadUrl String
  maxDownloads Int      @default(3)
  downloadCount Int     @default(0)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  @@index([token])
  @@index([orderId])
  @@index([expiresAt])
}

model FlashSale {
  id         Int      @id @default(autoincrement())
  productId  Int
  discount   Int      // percentage
  startTime  DateTime
  endTime    DateTime
  active     Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([active, startTime, endTime])
  @@index([productId])
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@index([email])
  @@index([active])
}

model B2BApplication {
  id          Int      @id @default(autoincrement())
  companyName String
  email       String   @unique
  phone       String?
  vatNumber   String?
  status      String   @default("pending") // pending | approved | rejected
  creditLimit Int      @default(0)         // pence
  createdAt   DateTime @default(now())
  @@index([email])
  @@index([status])
}

model Affiliate {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  website        String?
  type           String   @default("affiliate")
  code           String   @unique
  couponCode     String?  @unique
  commissionRate Float    @default(5)
  totalClicks    Int      @default(0)
  totalEarnings  Float    @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  @@index([code])
  @@index([active])
  @@index([email])
}

model MFAConfig {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  secret      String
  backupCodes String[]
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([email])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscription String   // JSON PushSubscription object
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([email])
}
