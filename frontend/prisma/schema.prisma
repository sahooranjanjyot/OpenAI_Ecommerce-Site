// Prisma schema — GroceryOS
// Optimized for PostgreSQL with full indexing across all 40 models to prevent full table scans.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            Int            @id @default(autoincrement())
  email         String?        @unique
  passwordHash  String?
  name          String
  phone         String         @unique
  address       String?
  sessionToken  String?
  loyaltyPoints Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  blocked       Boolean        @default(false)
  notes         String?
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([sessionToken])
}

model Employee {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  password     String
  passwordHash String?
  name         String
  role         String   @default("cashier")
  modules      String   @default("Instore POS,Orders")
  active       Boolean  @default(true)
  pin          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([role, active])
}

model Product {
  id             Int              @id @default(autoincrement())
  name           String
  category       String
  price          Int
  wasPrice       Int?
  onSale         Boolean          @default(false)
  promo          String?
  stock          Float            @default(0)
  unit           String           @default("Piece")
  image          String?
  description    String?
  enabled        Boolean          @default(true)
  hidden         Boolean          @default(false)
  featured       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  barcode        String?          @unique
  vatRate        Int              @default(20)
  sku            String?          @unique
  
  inventoryBatches  InventoryBatch[]
  recentlyViewed    RecentlyViewed[]
  subscriptions     Subscription[]
  variants          ProductVariant[]
  orderItems        OrderItem[]
  wishlistItems     WishlistItem[]
  backInStockAlerts BackInStockAlert[]
  qaItems           ProductQA[]
  b2bPrices         B2BPrice[]
  layaways          Layaway[]
  reviews           Review[]

  @@index([category])
  @@index([enabled, category])
  @@index([enabled, featured])
  @@index([sku])
  @@index([barcode])
  @@index([createdAt])
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  attribute String
  value     String
  price     Int
  stock     Int      @default(0)
  sku       String   @default("")
  image     String   @default("")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sku])
}

model Order {
  id               Int                   @id @default(autoincrement())
  customerId       Int
  status           String                @default("new")
  statusNote       String?
  total            Int
  shippingAddr     String?
  shippingCost     Int                   @default(0)
  discountAmount   Int                   @default(0)
  couponCode       String?
  affiliateCode    String?
  affiliateTracked Boolean               @default(false)
  notes            String?
  idempotencyKey   String?               @unique
  stripePaymentIntentId String?           @unique
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  
  customer         Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items            OrderItem[]
  refunds          Refund[]
  returns          Return[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([idempotencyKey])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Int
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  orderId   Int?
  rating    Int
  title     String
  body      String
  author    String
  email     String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([productId])
  @@index([productId, approved])
  @@index([email])
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  email     String
  productId Int
  createdAt DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, productId])
  @@index([email])
  @@index([productId])
}

model Coupon {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  type          String
  value         Int
  minOrderValue Int       @default(0)
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([code])
  @@index([active, expiresAt])
}

model GiftCard {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  balance        Int
  initialBalance Int
  recipientEmail String?
  message        String   @default("")
  issuedBy       String   @default("admin")
  active         Boolean  @default(true)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([code])
  @@index([active])
}

model LoyaltyAccount {
  id           Int                  @id @default(autoincrement())
  email        String               @unique
  points       Int                  @default(0)
  tier         String               @default("bronze")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions LoyaltyTransaction[]

  @@index([email])
}

model LoyaltyTransaction {
  id             Int            @id @default(autoincrement())
  email          String
  type           String
  points         Int
  description    String         @default("")
  createdAt      DateTime       @default(now())
  loyaltyAccount LoyaltyAccount @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([email])
  @@index([createdAt])
}

model Subscription {
  id           Int       @id @default(autoincrement())
  email        String
  productId    Int
  qty          Int       @default(1)
  frequency    String
  address      String
  phone        String
  nextDelivery DateTime
  active       Boolean   @default(true)
  cancelledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([productId])
  @@index([active, nextDelivery])
}

model AbandonedCart {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique
  email     String?
  items     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([email])
  @@index([createdAt])
}

model NewsletterSubscription {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  name           String    @default("")
  preferences    String    @default("[]")
  source         String    @default("website")
  subscribed     Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@index([subscribed])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  resource  String
  userId    String   @default("admin")
  ip        String   @default("")
  payload   String   @default("")
  checksum  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource])
}

model Refund {
  id          Int      @id @default(autoincrement())
  orderId     Int
  amount      Int
  reason      String
  type        String   @default("full")
  status      String   @default("processed")
  stripeRefundId String?
  processedBy String   @default("admin")
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model Return {
  id           Int      @id @default(autoincrement())
  orderId      Int
  productName  String
  quantity     Float
  reason       String
  condition    String
  refundAmount Int
  restocked    Boolean  @default(false)
  processedBy  String?
  createdAt    DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String    @default("")
  content     String
  category    String
  tags        String    @default("[]")
  image       String    @default("")
  published   Boolean   @default(false)
  publishedAt DateTime?
  views       Int       @default(0)
  author      String    @default("GroceryOS Team")
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published, publishedAt])
}

model Location {
  id        Int             @id @default(autoincrement())
  name      String
  type      String          @default("store")
  address   String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  stock     LocationStock[]

  @@index([active])
}

model LocationStock {
  id         Int      @id @default(autoincrement())
  locationId Int
  productId  Int
  qty        Float    @default(0)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([locationId])
  @@index([productId])
}

model PriceRule {
  id        Int       @id @default(autoincrement())
  name      String
  type      String
  target    String
  discount  Float
  minQty    Int       @default(1)
  startAt   DateTime?
  endAt     DateTime?
  active    Boolean   @default(true)
  priority  Int       @default(50)
  createdAt DateTime  @default(now())

  @@index([active, startAt, endAt])
}

model ModerationQueue {
  id            Int       @id @default(autoincrement())
  type          String
  content       String
  author        String
  email         String
  referenceId   Int       @default(0)
  flagged       Boolean   @default(false)
  reasons       String    @default("[]")
  score         Int       @default(0)
  status        String    @default("pending")
  moderatorNote String?
  moderatedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([type, status])
  @@index([status, createdAt])
}

model DigitalDownload {
  id           Int      @id @default(autoincrement())
  productId    Int
  token        String   @unique
  downloadUrl  String
  licenseType  String   @default("single_use")
  maxDownloads Int      @default(5)
  downloads    Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model FlashSale {
  id         Int      @id @default(autoincrement())
  name       String
  discount   Float
  productIds String
  startAt    DateTime
  endAt      DateTime
  maxUses    Int?
  usedCount  Int      @default(0)
  code       String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active, startAt, endAt])
}

model Supplier {
  id           Int      @id @default(autoincrement())
  name         String
  contact      String   @default("")
  email        String   @default("")
  phone        String   @default("")
  address      String   @default("")
  leadTimeDays Int      @default(3)
  notes        String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([active])
}

model Affiliate {
  id             Int                   @id @default(autoincrement())
  name           String
  email          String                @unique
  code           String                @unique
  type           String                @default("affiliate")
  website        String?
  commissionRate Float                 @default(5)
  totalClicks    Int                   @default(0)
  totalOrders    Int                   @default(0)
  totalEarnings  Int                   @default(0)
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  conversions    AffiliateConversion[]

  @@index([email])
  @@index([code])
  @@index([active])
}

model AffiliateConversion {
  id          Int       @id @default(autoincrement())
  affiliateId Int
  orderId     Int
  orderTotal  Int
  commission  Int
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([orderId])
}

model B2BAccount {
  id            Int        @id @default(autoincrement())
  companyName   String
  contactName   String
  email         String     @unique
  phone         String
  website       String?
  vatNumber     String?
  companyReg    String?
  monthlyVolume Float?
  creditTerms   String     @default("pay_on_order")
  industry      String?
  status        String     @default("pending")
  discountRate  Float      @default(0)
  creditLimit   Int        @default(0)
  createdAt     DateTime   @default(now())
  b2bPrices     B2BPrice[]

  @@index([email])
  @@index([status])
}

model B2BPrice {
  id         Int        @id @default(autoincrement())
  accountId  Int
  productId  Int
  price      Int
  minQty     Int        @default(1)
  b2bAccount B2BAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([accountId, productId])
  @@index([accountId])
  @@index([productId])
}

model Layaway {
  id            Int      @id @default(autoincrement())
  email         String
  productId     Int
  qty           Int      @default(1)
  instalments   Int
  totalAmount   Int
  depositAmount Int
  depositPct    Float
  remaining     Int
  paidAmount    Int      @default(0)
  paidCount     Int      @default(0)
  address       String
  phone         String
  schedule      String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([status])
  @@index([productId])
}

model RecentlyViewed {
  id        Int      @id @default(autoincrement())
  email     String
  productId Int
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
  @@index([email])
  @@index([productId])
}

model InventoryBatch {
  id         Int       @id @default(autoincrement())
  productId  Int
  quantity   Float     @default(0)
  remaining  Float     @default(0)
  costPrice  Int       @default(0)
  supplier   String?
  channel    String    @default("admin")
  expiryDate DateTime?
  batchRef   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@index([expiryDate])
}

model BackInStockAlert {
  id        Int      @id @default(autoincrement())
  email     String
  productId Int
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
  @@index([email])
  @@index([productId])
  @@index([notified])
}

model Bundle {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  productIds  String
  discount    Float    @default(10)
  enabled     Boolean  @default(true)
  image       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

model SupportTicket {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  subject    String
  message    String
  orderId    Int?
  status     String   @default("open")
  priority   String   @default("medium")
  assignedTo String?
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model ProductQA {
  id         Int       @id @default(autoincrement())
  productId  Int
  question   String
  author     String
  email      String
  answer     String?
  answeredBy String?
  isStaff    Boolean   @default(false)
  answered   Boolean   @default(false)
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([answered])
}

model MFAConfig {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  secret      String
  backupCodes String[]
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscription String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}
