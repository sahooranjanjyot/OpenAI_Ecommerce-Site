generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Float
  wasPrice    Float?
  onSale      Boolean  @default(false)
  promo       String?
  stock       Float    @default(0)
  unit        String   @default("Piece")
  image       String?
  description String?
  enabled     Boolean  @default(true)
  hidden      Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batches     InventoryBatch[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?  @unique
  password  String?
  address   String?
  orders    Int      @default(0)
  notes     String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Order     Order[]
}

model Order {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  status     String   @default("new")
  total      Float
  items      String
  address    String?
  createdAt  DateTime @default(now())
  returns    Return[]
}

model Promo {
  id        Int      @id @default(autoincrement())
  type      String
  target    String
  start     String
  end       String
  active    Boolean  @default(true)
  buyX      Int?
  payY      Int?
  crossTarget String?
  crossDiscount Int?
  createdAt DateTime @default(now())
}

model InventoryBatch {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float    @default(0)
  remaining   Float    @default(0)
  costPrice   Float    @default(0.0)
  supplier    String?
  channel     String   @default("admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Return {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id])
  productName  String
  quantity     Float
  reason       String
  condition    String
  refundAmount Float
  restocked    Boolean
  processedBy  String
  createdAt    DateTime @default(now())
}
